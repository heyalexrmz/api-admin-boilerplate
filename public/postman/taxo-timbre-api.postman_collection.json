{
  "info": {
    "name": "Taxo Timbre API",
    "description": "Postman collection for submitting tickets and reading ticket status.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.taxotimbre.com",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "tt_live_xxx",
      "type": "string"
    },
    {
      "key": "ticket_id",
      "value": "4b96e5de-69de-4dc8-aad7-4d5045fa5b31",
      "type": "string"
    },
    {
      "key": "tax_id",
      "value": "EKU9003173C9",
      "type": "string"
    },
    {
      "key": "ticket_image_base64",
      "value": "/9j/4AAQSkZJRgABAQAAAQABAAD...",
      "type": "string"
    },
    {
      "key": "csf_pdf_base64",
      "value": "JVBERi0xLjQKJcTl8uXr...",
      "type": "string"
    },
    {
      "key": "taxpayer",
      "value": "Empresa Demo",
      "type": "string"
    },
    {
      "key": "taxpayer_name",
      "value": "ALEJANDRO",
      "type": "string"
    },
    {
      "key": "taxpayer_last_name",
      "value": "DOMINGUEZ",
      "type": "string"
    },
    {
      "key": "taxpayer_second_last_name",
      "value": "RAMIREZ",
      "type": "string"
    },
    {
      "key": "postal_code",
      "value": "01234",
      "type": "string"
    },
    {
      "key": "invoice_fiscal_regimen",
      "value": "612",
      "type": "string"
    },
    {
      "key": "invoice_cfdi_use",
      "value": "G03",
      "type": "string"
    },
    {
      "key": "country",
      "value": "México",
      "type": "string"
    },
    {
      "key": "taxpayer_type",
      "value": "persona_fisica",
      "type": "string"
    },
    {
      "key": "create_ticket_payload",
      "value": "{}",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Create ticket",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const taxpayerType = pm.collectionVariables.get('taxpayer_type') || 'persona_fisica';",
                  "",
                  "const payload = {",
                  "  tax_id: pm.collectionVariables.get('tax_id'),",
                  "  country: pm.collectionVariables.get('country'),",
                  "  postal_code: pm.collectionVariables.get('postal_code'),",
                  "  invoice_fiscal_regimen: pm.collectionVariables.get('invoice_fiscal_regimen'),",
                  "  invoice_cfdi_use: pm.collectionVariables.get('invoice_cfdi_use'),",
                  "  csf_pdf: pm.collectionVariables.get('csf_pdf_base64'),",
                  "  file_name: 'ticket.jpg',",
                  "  file: pm.collectionVariables.get('ticket_image_base64'),",
                  "};",
                  "",
                  "if (taxpayerType === 'persona_moral') {",
                  "  payload.taxpayer = pm.collectionVariables.get('taxpayer');",
                  "} else {",
                  "  payload.taxpayer_name = pm.collectionVariables.get('taxpayer_name');",
                  "  payload.taxpayer_last_name = pm.collectionVariables.get('taxpayer_last_name');",
                  "  payload.taxpayer_second_last_name = pm.collectionVariables.get('taxpayer_second_last_name');",
                  "  payload.taxpayer = [",
                  "    payload.taxpayer_name,",
                  "    payload.taxpayer_last_name,",
                  "    payload.taxpayer_second_last_name,",
                  "  ].filter(Boolean).join(' ');",
                  "}",
                  "",
                  "for (const [key, value] of Object.entries(payload)) {",
                  "  if (value === undefined || value === null || String(value).trim() === '') {",
                  "    delete payload[key];",
                  "  }",
                  "}",
                  "",
                  "pm.collectionVariables.set('create_ticket_payload', JSON.stringify(payload, null, 2));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Idempotency-Key",
                "value": "{{$guid}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{create_ticket_payload}}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tickets"
              ]
            },
            "description": "Submit a ticket image with JSON/base64. Set taxpayer_type to persona_fisica or persona_moral; the pre-request script builds the correct payload for the same POST /api/v1/tickets endpoint."
          },
          "description": "Single create-ticket endpoint for persona fisica and persona moral RFCs. Change taxpayer_type to persona_fisica or persona_moral before sending."
        },
        {
          "name": "List tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets?limit=25&status=finalized",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tickets"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                },
                {
                  "key": "status",
                  "value": "finalized",
                  "description": "received, queued, pending, processing, finalized, failed, or cancelled"
                }
              ]
            },
            "description": "List recent tickets. Requires a read, admin, or access API key."
          }
        },
        {
          "name": "List tickets - Invalid API key",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets?limit=25&status=finalized",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tickets"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "25"
                },
                {
                  "key": "status",
                  "value": "finalized",
                  "description": "received, queued, pending, processing, finalized, failed, or cancelled"
                }
              ]
            },
            "description": "Editable failure request for validating invalid API key handling.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "invalid_api_key",
                  "type": "string"
                }
              ]
            }
          }
        },
        {
          "name": "Get ticket",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/{{ticket_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tickets",
                "{{ticket_id}}"
              ]
            },
            "description": "Fetch one ticket by id, including invoice and document references when available."
          }
        },
        {
          "name": "Get ticket - Not found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/tickets/00000000-0000-0000-0000-000000000000",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tickets",
                "00000000-0000-0000-0000-000000000000"
              ]
            },
            "description": "Editable failure request for validating ticket not found handling."
          }
        }
      ]
    }
  ]
}
