# PostgreSQL connection string. `pnpm db:up` starts a local Postgres 17
# container on port 5433 (mapped in docker-compose.yml) so it doesn't clash
# with any host Postgres on 5432.
DATABASE_URL=postgresql://demo:demo@localhost:5433/demo

# Better Auth. Generate a secret with: openssl rand -base64 32
# BETTER_AUTH_URL must match the URL users access the app from.
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Resend (https://resend.com/api-keys). In development, leave RESEND_API_KEY
# as the placeholder below and magic-link URLs are logged to the server console
# instead of being emailed — so you can click them without a real key.
# For production email delivery, set a real key and a verified sender.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Acme <onboarding@resend.dev>
